                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                614,
                240
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> x<-seq(-3, 3, length=500) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> p<-dnorm(x, 0, 1) "
                            }
