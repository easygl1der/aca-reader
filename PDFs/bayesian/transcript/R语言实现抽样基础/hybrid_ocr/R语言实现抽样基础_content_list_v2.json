                918
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "连续型随机变量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                140,
                444,
                238
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "已知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": " 密度函数为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f(x)"
                    },
                    {
                        "type": "text",
                        "content": " 。根据以上密度函数抽取 100 个样本。"
                    }
                ]
            },
            "bbox": [
                67,
                288,
                815,
                357
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "在  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": " 的支撑（取值范围，设为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[a, b]"
                    },
                    {
                        "type": "text",
                        "content": "）内均匀地“打格子点”，即令  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a = x_{1} \\leq \\cdots \\leq x_{n} = b"
                    },
                    {
                        "type": "text",
                        "content": "，且  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x_{i}"
                    },
                    {
                        "type": "text",
                        "content": " 的间隔一样，并计算  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p_{i} = f(x_{i})"
                    },
                    {
                        "type": "text",
                        "content": "，然后按离散概率的抽样方式从  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x_{i}"
                    },
                    {
                        "type": "text",
                        "content": " 中抽取 100 个样本即可。"
                    }
                ]
            },
            "bbox": [
                63,
                525,
                933,
                783
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "连续型随机变量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                444,
                235
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} P (X = x _ {i}) \\approx P (x _ {i} \\leq X \\leq x _ {i} + \\Delta x) = P (X \\leq x _ {i} + \\Delta x) - P (X \\leq x _ {i}) = \\\\ F (x _ {i} + \\Delta x) - F (x _ {i}) = F ^ {\\prime} (\\xi) \\cdot \\Delta x = f (\\xi) \\cdot \\Delta x \\approx f (x _ {i}) \\Delta x \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7d9d5895c16930c5cff5c5c87b33644151965177799b972a4cb4db4d4bbe185d.jpg"
                }
            },
            "bbox": [
                75,
                294,
                915,
                448
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\xi \\in [ x _ {i}, x _ {i} + \\Delta x ]",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4b7c1164c689f5f89d142c6f68801d601df599a8dc92a6a1446f539121c226b7.jpg"
                }
            },
            "bbox": [
                75,
                505,
                272,
                562
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "可见， "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P(X = x_{i}) \\propto f(x_{i})"
                    },
                    {
                        "type": "text",
                        "content": "。"
                    }
                ]
            },
            "bbox": [
                79,
                735,
                416,
                794
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "例：从U(0,1)中抽取样本"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                614,
                240
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> x<-seq(0, 1, length=500) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> p<-rep(1/500, 500) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> x_sample<-sample(x, 100, replace=T, prob=p) "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                91,
                296,
                654,
                546
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "注: p不一定需要是概率"
                    }
                ]
            },
            "bbox": [
                101,
                670,
                409,
                729
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "> p<-rep(1, 500) "
                    }
                ]
            },
            "bbox": [
                94,
                770,
                288,
                825
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
