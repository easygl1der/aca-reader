    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "二维离散型随机向量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                140,
                544,
                240
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "已知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P\\left(X = x_{i}, Y = y_{j}\\right) = p_{ij}, i = 1, \\ldots, I; j = 1, \\ldots, J"
                    },
                    {
                        "type": "text",
                        "content": " 。根据以上概率分布抽取 100 个样本。"
                    }
                ]
            },
            "bbox": [
                83,
                303,
                922,
                466
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "把数据矩阵“拉直”为一个向量，即令  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P(Z = k) = P\\big(X = x_{i}, Y = y_{j}\\big), k = 1,2,\\ldots,I \\times J"
                    },
                    {
                        "type": "text",
                        "content": "，并记此概率为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde{p}_{k}"
                    },
                    {
                        "type": "text",
                        "content": "。然后按照离散型随机变量的方式抽取100个  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z"
                    },
                    {
                        "type": "text",
                        "content": " 的样本，并把  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": " 对应回  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x_{i}"
                    },
                    {
                        "type": "text",
                        "content": " 和  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y_{j}"
                    },
                    {
                        "type": "text",
                        "content": " 即可。"
                    }
                ]
            },
            "bbox": [
                81,
                592,
                922,
                894
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "二维离散型随机向量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                542,
                235
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": ">\\mathrm{x}<-\\mathrm{c}(\\ldots);\\mathrm{y}<-\\mathrm{c}(\\ldots);\\mathrm{l}<-\\mathrm{length}(\\mathrm{x});\\mathrm{J}<-\\mathrm{length}(\\mathrm{y})"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": ">  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p<-matrix(..., nrow=1, ncol=J)"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> p2<-as.vector(p) #注：按列拉直 "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index<-sample(1:(I*J), 100, replace=T, prob=p2) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index1<- (index-1)%%|+1; index2<- (index-1)%%|+1 "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> data_sample<-cbind(x[index1], y[index2]) "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                84,
                300,
                709,
                879
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "二维离散型随机向量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                140,
                544,
                238
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. 计算  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": " 的边缘概率，并记为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p_{i + }"
                            },
                            {
                                "type": "text",
                                "content": " 。按照  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p_{i + }"
                            },
                            {
                                "type": "text",
                                "content": " 的概率从  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x_{i}"
                            },
                            {
                                "type": "text",
                                "content": " 中抽取 100 个样本，记为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x_{1}^{*}, \\ldots, x_{100}^{*}"
                            },
                            {
                                "type": "text",
                                "content": " 。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. 对  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k = 1, \\ldots, 100"
                            },
                            {
                                "type": "text",
                                "content": ", 计算条件概率  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P(Y = y_{j} | X = x_{k}^{*})"
                            },
                            {
                                "type": "text",
                                "content": ", 并记为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p_{j \\mid k}^{*}"
                            },
                            {
                                "type": "text",
                                "content": " 。按照  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p_{j \\mid k}^{*}"
                            },
                            {
                                "type": "text",
                                "content": " 的概率从  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y_{j}"
                            },
                            {
                                "type": "text",
                                "content": " 中抽取壹个样本, 并记为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y_{k}^{*}"
                            },
                            {
                                "type": "text",
                                "content": " 。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. 样本  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "(x_{1}^{*}, y_{1}^{*}), \\ldots, (x_{100}^{*}, y_{100}^{*})"
                            },
                            {
                                "type": "text",
                                "content": " 即为所得。"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                83,
                292,
                922,
                807
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "二维离散型随机向量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                542,
                235
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": ">\\mathrm{x}<-\\mathrm{c}(\\ldots);\\quad \\mathrm{y}<-\\mathrm{c}(\\ldots);\\quad \\mathrm{l}<-\\mathrm{length}(\\mathrm{x});\\quad \\mathrm{J}<-\\mathrm{length}(\\mathrm{y})"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> p<-matrix(..., nrow=1, ncol=J); px<-rowSums(p) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index1<-sample(1:I, 100, replace=T, prob=px) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index2<-numeric(100) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> for (i in 1:100) { index2[i]<-sample(1:J, 1, prob=p[index1[i],])} "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> data_sample<-cbind(x[index1], y[index2]) "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                83,
                296,
                837,
                881
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "二维离散型随机向量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                542,
                235
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": ">\\mathrm{x}<-\\mathrm{c}(\\ldots);\\quad \\mathrm{y}<-\\mathrm{c}(\\ldots);\\quad \\mathrm{l}<-\\mathrm{length}(\\mathrm{x});\\quad \\mathrm{J}<-\\mathrm{length}(\\mathrm{y})"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> p<-matrix(..., nrow=1, ncol=J); py<-colSums(p) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index2<-sample(1:J, 100, replace=T, prob=py) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> index1<-numeric(100) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> for (i in 1:100) { index1[i]<-sample(1:i, 1, prob=p[,index2[i]])} "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "> data_sample<-cbind(x[index1], y[index2]) "
                            }
                        ]
                    }
