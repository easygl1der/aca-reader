    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "离散型随机变量"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                444,
                235
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "已知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P\\left(X = x_{i}\\right) = p_{i}, i = 1, \\ldots, n"
                    },
                    {
                        "type": "text",
                        "content": " 。根据以上概率分布抽取 100 个样本。"
                    }
                ]
            },
            "bbox": [
                83,
                296,
                893,
                450
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} > x <   - c (\\dots); p <   - c (\\dots); n <   - l e n g t h (x) \\\\ > \\text {i n d e x} <   - \\text {s a m p l e} (1: n, 1 0 0, \\text {r e p l a c e} = T, \\text {p r o b} = p); x _ {\\text {s a m p l e}} <   - x [ \\text {i n d e x} ] \\\\ > x \\_ s a m p l e <   - s a m p l e (x, 1 0 0, r e p l a c e = T, p r o b = p) \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a6616b45942e6acb99828184a55514b6d11f0f2591e099afc26c25b105da8581.jpg"
                }
            },
            "bbox": [
