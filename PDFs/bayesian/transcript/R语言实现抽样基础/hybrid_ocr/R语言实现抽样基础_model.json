                0.095,
                0.771,
                0.289,
                0.826
            ],
            "angle": 0,
            "content": "> p<-rep(1, 500)"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.615,
                0.242
            ],
