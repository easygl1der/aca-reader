        },
        {
            "type": "text",
            "bbox": [
                0.095,
                0.486,
                0.655,
                0.548
            ],
            "angle": 0,
            "content": "> x_sample<-sample(x, 100, replace=T, prob=p)"
        },
        {
            "type": "list",
