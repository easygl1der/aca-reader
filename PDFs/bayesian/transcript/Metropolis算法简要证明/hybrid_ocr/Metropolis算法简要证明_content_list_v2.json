        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} f _ {X _ {t + 1}, X _ {t}} (b, a) = f _ {X _ {t + 1} | X _ {t}} (b | a) \\times f _ {X _ {t}} (a) \\doteq T (b | a) \\times f _ {X _ {t}} (a) \\\\ = T (a | b) \\times f _ {X _ {t}} (b) \\doteq f _ {X _ {t + 1} | X _ {t}} (a | b) \\times f _ {X _ {t}} (b) = f _ {X _ {t + 1}, X _ {t}} (a, b) 。 \\\\ \\end{array}",
                "math_type": "latex",
