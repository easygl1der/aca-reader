                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. 若  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "u \\leq \\min \\{r, 1\\}"
                            },
                            {
                                "type": "text",
                                "content": ", 则令  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x^{t} = x^{*}"
                            },
                            {
                                "type": "text",
                                "content": "; 否则令  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x^{t} = x^{t - 1}"
                            }
                        ]
