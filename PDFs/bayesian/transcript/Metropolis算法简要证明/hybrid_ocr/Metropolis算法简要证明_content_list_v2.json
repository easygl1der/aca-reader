                        "type": "equation_inline",
                        "content": "X_{t + 1}"
                    },
                    {
                        "type": "text",
                        "content": " 的密度函数仍为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f_{X_t}"
                    },
                    {
                        "type": "text",
                        "content": "，故  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f_{X_t}"
                    },
                    {
                        "type": "text",
                        "content": " 为平稳分布。"
