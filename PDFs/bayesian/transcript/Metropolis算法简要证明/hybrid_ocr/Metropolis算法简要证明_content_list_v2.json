                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. 给定  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x^{t - 1}"
                            },
                            {
                                "type": "text",
                                "content": ", 从建议分布  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "J(x^{t} \\mid x^{t - 1})"
                            },
                            {
                                "type": "text",
                                "content": " 中抽取样本, 并记为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x^{*}"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. 计算  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "r = \\frac{f(x^{*})}{f(x^{t - 1})}"
                            },
                            {
                                "type": "text",
                                "content": ", 并从  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U[0,1]"
                            },
                            {
                                "type": "text",
                                "content": " 中抽取  "
