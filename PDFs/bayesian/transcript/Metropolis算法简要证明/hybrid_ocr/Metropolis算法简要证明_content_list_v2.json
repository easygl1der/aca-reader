            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} f _ {X _ {t + 1}} (b) = \\int f _ {X _ {t + 1}, X _ {t}} (b, a) d a = \\int f _ {X _ {t + 1}, X _ {t}} (a, b) d a \\\\ = \\int f _ {X _ {t + 1} | X _ {t}} (a | b) \\times f _ {X _ {t}} (b) d a = f _ {X _ {t}} (b) \\times \\int f _ {X _ {t + 1} | X _ {t}} (a | b) d a = f _ {X _ {t}} (b) \\circ \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/861be74a39abf275facb68070ef17f9a1de4af12aebcd0dad06ec87a3cef7e3b.jpg"
