[
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.46,
                0.388,
                0.621
            ],
            "angle": 0,
            "content": "p值补充"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.092,
                0.144,
                0.326,
                0.246
            ],
            "angle": 0,
            "content": "\\(p\\) 值的定义"
        },
        {
            "type": "title",
            "bbox": [
                0.244,
                0.3,
                0.453,
                0.345
            ],
            "angle": 0,
            "content": "CLASSICAL \\(p\\) -VALUES"
        },
        {
            "type": "text",
            "bbox": [
                0.247,
                0.409,
                0.591,
                0.448
            ],
            "angle": 0,
            "content": "The classical \\( p \\)-value for the test statistic \\( T(y) \\) is"
        },
        {
            "type": "equation",
            "bbox": [
                0.406,
                0.501,
                0.606,
                0.545
            ],
            "angle": 0,
            "content": "\\[\np _ {C} = \\Pr \\left(T (y ^ {\\text {r e p}}) \\geq T (y) | \\theta\\right).\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.262,
                0.639,
                0.733,
                0.674
            ],
            "angle": 0,
            "content": "The probability is taken over the distribution of \\( y^{\\mathrm{rep}} \\) with \\( \\theta \\) fixed."
        },
        {
            "type": "title",
            "bbox": [
                0.248,
                0.764,
                0.297,
                0.794
            ],
            "angle": 0,
            "content": "NOTE"
        },
        {
            "type": "text",
            "bbox": [
                0.247,
                0.805,
                0.769,
                0.886
            ],
            "angle": 0,
            "content": "The distribution of \\( y^{\\mathrm{rep}} \\) given \\( y \\) and \\( \\theta \\) is the same as its distribution given \\( \\theta \\) alone."
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.72,
                0.246
            ],
            "angle": 0,
            "content": "经典检验问题的 \\(p\\) 值计算公式"
        },
        {
            "type": "text",
            "bbox": [
                0.09,
                0.321,
                0.596,
                0.382
            ],
            "angle": 0,
            "content": "已知 \\(y_{1}, \\ldots, y_{n} \\sim N(\\theta , 1)\\), 检验 \\(\\mathrm{H}_{0}\\): \\(\\theta = \\theta_{0}\\) 。"
        },
        {
            "type": "equation",
            "bbox": [
                0.089,
                0.454,
                0.298,
                0.505
            ],
            "angle": 0,
            "content": "\\[\n\\triangleright y = \\left(y _ {1}, \\dots , y _ {n}\\right)\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.088,
                0.602,
                0.389,
                0.699
            ],
            "angle": 0,
            "content": "\\(\\succ\\) 统计量为 \\(T(y) = \\frac{\\bar{y} - \\theta_0}{1 / \\sqrt{n}}\\)"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.72,
                0.245
            ],
            "angle": 0,
            "content": "经典检验问题的 \\(p\\) 值计算公式"
        },
        {
            "type": "text",
            "bbox": [
                0.086,
                0.298,
                0.263,
                0.358
            ],
            "angle": 0,
            "content": "\\(p\\) 值计算公式:"
        },
        {
            "type": "equation",
            "bbox": [
                0.085,
                0.416,
                0.903,
                0.709
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} \\triangleright H _ {1} \\colon \\theta > \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) > T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta <   \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) <   T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta \\neq \\theta_ {0} \\colon p _ {c} = P \\{| N (0, 1) | > | T (y) | \\} = 2 P \\{N (0, 1) > | T (y) | \\} \\\\ \\end{array}\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.086,
                0.831,
                0.483,
                0.893
            ],
            "angle": 0,
            "content": "若 \\(p_{c}< \\alpha\\) （接近0），则拒绝 \\(\\mathrm{H}_{0}\\)"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.464,
                0.246
            ],
            "angle": 0,
            "content": "从 \\(y^{\\mathrm{rep}}\\) 角度看 \\(p\\) 值"
        },
        {
            "type": "text",
            "bbox": [
                0.068,
                0.294,
                0.69,
                0.358
            ],
            "angle": 0,
            "content": "假设 \\(\\mathrm{H}_{0}\\) 成立, 即 \\(\\theta = \\theta_{0}\\), 亦即 \\(y_{1}, \\ldots, y_{n} \\sim N\\left(\\theta_{0}, 1\\right)\\) 。"
        },
        {
            "type": "text",
            "bbox": [
                0.068,
                0.48,
                0.931,
                0.647
            ],
            "angle": 0,
            "content": "现从 \\(N(\\theta_0, 1)\\) 中生成的重复数据（replicated data），记为 \\(y^{\\mathrm{rep}} = (y_1^{\\mathrm{rep}}, \\ldots, y_n^{\\mathrm{rep}})\\)。"
        },
        {
            "type": "text",
            "bbox": [
                0.072,
                0.771,
                0.931,
                0.919
            ],
            "angle": 0,
            "content": "由于 \\(y ^{\\mathrm {r e p}}\\) 与 \\(y\\) 来自同一分布, 所谓 “同源”, 因此由 \\(y ^{\\mathrm {r e p}}\\) 与 \\(y\\) 应该 “相差无几”。"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.464,
                0.246
            ],
            "angle": 0,
            "content": "从 \\(y^{\\mathrm{rep}}\\) 角度看 \\(p\\) 值"
        },
        {
            "type": "text",
            "bbox": [
                0.08,
                0.316,
                0.894,
                0.501
            ],
            "angle": 0,
            "content": "考虑 \\(\\bar{y}^{\\mathrm{rep}}\\) 与 \\(\\bar{y}\\) 的大小关系：由于 \\(\\bar{y}^{\\mathrm{rep}}\\) 是 \\(\\theta_0\\) 的“代表值”，\\(\\bar{y}\\) 是 \\(\\theta\\) 的“代表值”。"
        },
        {
            "type": "text",
            "bbox": [
                0.067,
                0.587,
                0.893,
                0.656
            ],
            "angle": 0,
            "content": "若 \\(\\mathrm{H}_{0}\\) 成立（\\(\\theta = \\theta_{0}\\)），则可以预计：\\(P(\\overline{y}^{\\mathrm{rep}} > \\overline{y})\\) 应该接近 0.5。"
        },
        {
            "type": "text",
            "bbox": [
                0.067,
                0.732,
                0.802,
                0.802
            ],
            "angle": 0,
            "content": "反之，若 \\(P(\\overline{y}^{\\mathrm{rep}} > \\overline{y})\\) 接近 0 或接近 1；则认为 \\(\\mathrm{H}_{0}\\) 不成立。"
        },
        {
            "type": "list",
            "bbox": [
                0.067,
                0.587,
                0.893,
                0.802
            ],
            "angle": 0,
            "content": null
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.095,
                0.144,
                0.397,
                0.237
            ],
            "angle": 0,
            "content": "统计量的引入"
        },
        {
            "type": "image",
            "bbox": [
                0.084,
                0.279,
                0.919,
                0.877
            ],
            "angle": 0,
            "content": null
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.144,
                0.297,
                0.236
            ],
            "angle": 0,
            "content": "单边检验"
        },
        {
            "type": "text",
            "bbox": [
                0.02,
                0.275,
                0.488,
                0.567
            ],
            "angle": 0,
            "content": "若此概率接近0，则拒绝 \\(\\mathrm{H}_{0}\\) 。进一步， \\(P\\{N(0,1) > T(y)\\} \\approx 0\\) ，由于 \\(\\bar{y}^{\\mathrm{rep}} > \\bar{y}\\) 为小概率事件，故认为 \\(\\theta_{0} < \\theta\\) ，即 \\(\\mathrm{H}_{1}: \\theta > \\theta_{0}\\) 成立。"
        },
        {
            "type": "text",
            "bbox": [
                0.019,
                0.618,
                0.472,
                0.914
            ],
            "angle": 0,
            "content": "若此概率接近1, 则拒绝 \\(\\mathrm{H}_{0}\\) 。进一步, \\(P\\{N(0,1) > T(y)\\} \\approx 1\\) 等价于 \\(P\\{N(0,1) < T(y)\\} \\approx 0\\) 。由于 \\(\\bar{y}^{\\text {rep}} < \\bar{y}\\) 为小概率事件, 故认为 \\(\\theta_{0} > \\theta\\), 即 \\(\\mathrm{H}_{1}: \\theta < \\theta_{0}\\) 成立。"
        },
        {
            "type": "list",
            "bbox": [
                0.019,
                0.275,
                0.488,
                0.914
            ],
            "angle": 0,
            "content": null
        },
        {
            "type": "text",
            "bbox": [
                0.53,
                0.275,
                0.686,
                0.33
            ],
            "angle": 0,
            "content": "\\(p\\) 值计算公式:"
        },
        {
            "type": "equation",
            "bbox": [
                0.531,
                0.379,
                0.948,
                0.539
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} \\triangleright H _ {1} \\colon \\theta > \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) > T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta <   \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) <   T (y) \\} \\\\ \\end{array}\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.532,
                0.662,
                0.875,
                0.719
            ],
            "angle": 0,
            "content": "若 \\(p_{c}< \\alpha\\) （接近0），则拒绝 \\(\\mathrm{H}_{0}\\)"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.144,
                0.297,
                0.236
            ],
            "angle": 0,
            "content": "双边检验"
        },
        {
            "type": "text",
            "bbox": [
                0.064,
                0.319,
                0.346,
                0.388
            ],
            "angle": 0,
            "content": "对 \\(H_{1}: \\theta \\neq \\theta_{0}\\), 则需要"
        },
        {
            "type": "equation",
            "bbox": [
                0.168,
                0.464,
                0.827,
                0.531
            ],
            "angle": 0,
            "content": "\\[\nP \\{N (0, 1) > T (y) \\} \\approx 0 \\quad {\\text {或}} \\quad P \\{N (0, 1) <   T (y) \\} \\approx 0\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.062,
                0.611,
                0.421,
                0.672
            ],
            "angle": 0,
            "content": "注：两者只能其中一个发生"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.297,
                0.236
            ],
            "angle": 0,
            "content": "双边检验"
        },
        {
            "type": "text",
            "bbox": [
                0.067,
                0.316,
                0.752,
                0.388
            ],
            "angle": 0,
            "content": "1. 若 \\(P\\{N(0,1) > T(y)\\} \\approx 0\\) ，则可知 \\(T(y) > 0\\) ，因此"
        },
        {
            "type": "equation",
            "bbox": [
                0.212,
                0.466,
                0.776,
                0.533
            ],
            "angle": 0,
            "content": "\\[\n0 \\approx P \\{N (0, 1) > T (y) \\} = P \\{N (0, 1) > | T (y) | \\}\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.061,
                0.608,
                0.744,
                0.675
            ],
            "angle": 0,
            "content": "2. 若 \\(P\\{N(0,1) < T(y)\\} \\approx 0\\), 则可知 \\(T(y) < 0\\), 因此"
        },
        {
            "type": "equation",
            "bbox": [
                0.071,
                0.758,
                0.927,
                0.828
            ],
            "angle": 0,
            "content": "\\[\n0 \\approx P \\{N (0, 1) <   T (y) \\} = P \\{N (0, 1) > - T (y) \\} = P \\{N (0, 1) > | T (y) | \\}\n\\]"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.297,
                0.236
            ],
            "angle": 0,
            "content": "双边检验"
        },
        {
            "type": "text",
            "bbox": [
                0.063,
                0.318,
                0.604,
                0.388
            ],
            "angle": 0,
            "content": "综合1.和2.可得：\\(p = 2P\\{N(0,1) > |T(y)|\\}\\)"
        },
        {
            "type": "text",
            "bbox": [
                0.063,
                0.498,
                0.243,
                0.56
            ],
            "angle": 0,
            "content": "\\(p\\) 值计算公式:"
        },
        {
            "type": "equation",
            "bbox": [
                0.068,
                0.616,
                0.882,
                0.678
            ],
            "angle": 0,
            "content": "\\[\n\\triangleright H _ {1} \\colon \\theta \\neq \\theta_ {0} \\colon p _ {c} = P \\{| N (0, 1) | > | T (y) | \\} = 2 P \\{N (0, 1) > | T (y) | \\}\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.063,
                0.8,
                0.463,
                0.864
            ],
            "angle": 0,
            "content": "若 \\(p_{c}< \\alpha\\) （接近0），则拒绝 \\(\\mathrm{H}_{0}\\)"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.146,
                0.491,
                0.237
            ],
            "angle": 0,
            "content": "概率的另一个方向"
        },
        {
            "type": "text",
            "bbox": [
                0.067,
                0.316,
                0.894,
                0.388
            ],
            "angle": 0,
            "content": "\\(\\succ\\) 若 \\(\\mathrm{H}_{0}\\) 成立（\\(\\theta = \\theta_{0}\\)），则可以预计：\\(P(\\bar{y}^{\\mathrm{rep}} < \\bar{y})\\) 应该接近 0.5。"
        },
        {
            "type": "text",
            "bbox": [
                0.067,
                0.463,
                0.803,
                0.531
            ],
            "angle": 0,
            "content": "反之，若 \\(P(\\bar{y}^{\\mathrm{rep}} < \\bar{y})\\) 接近 0 或接近 1；则认为 \\(\\mathrm{H}_{0}\\) 不成立。"
        },
        {
            "type": "list",
            "bbox": [
                0.067,
                0.316,
                0.894,
                0.531
            ],
            "angle": 0,
            "content": null
        },
        {
            "type": "text",
            "bbox": [
                0.078,
                0.768,
                0.902,
                0.853
            ],
            "angle": 0,
            "content": "思考: 根据 \\(P\\left(\\bar{y}^{\\text {rep}} < \\bar{y}\\right)\\) 是否可以得到如上的推导?"
        }
    ]
]