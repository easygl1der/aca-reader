    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "双边检验"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                142,
                296,
                233
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "对  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H_{1}: \\theta \\neq \\theta_{0}"
                    },
                    {
                        "type": "text",
                        "content": ", 则需要"
                    }
                ]
            },
            "bbox": [
                63,
                318,
                345,
                379
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P \\{N (0, 1) > T (y) \\} \\approx 0 \\quad {\\text {或}} \\quad P \\{N (0, 1) <   T (y) \\} \\approx 0",
                "math_type": "latex",
                "image_source": {
