    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "单边检验"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                142,
                296,
                235
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "若此概率接近0，则拒绝  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 。进一步，  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P\\{N(0,1) > T(y)\\} \\approx 0"
                            },
                            {
                                "type": "text",
                                "content": " ，由于  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\bar{y}^{\\mathrm{rep}} > \\bar{y}"
                            },
                            {
                                "type": "text",
                                "content": " 为小概率事件，故认为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta_{0}< \\theta"
                            },
                            {
                                "type": "text",
                                "content": " ，即  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{1}: \\theta > \\theta_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 成立。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "若此概率接近1，则拒绝  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 。进一步， "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P\\{N(0,1) > T(y)\\} \\approx 1"
                            },
                            {
                                "type": "text",
                                "content": " 等价于  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P\\{N(0,1) < T(y)\\} \\approx 0"
                            },
                            {
                                "type": "text",
                                "content": " 。由于  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\bar{y}^{\\mathrm{rep}} < \\bar{y}"
                            },
                            {
                                "type": "text",
                                "content": " 为小概率事件，故认为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta_{0} > \\theta"
                            },
                            {
                                "type": "text",
                                "content": " ，即  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{1}: \\theta < \\theta_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 成立。"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                20,
                277,
                486,
                912
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值计算公式:"
                    }
                ]
            },
            "bbox": [
                529,
                274,
                685,
                329
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\triangleright H _ {1} \\colon \\theta > \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) > T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta <   \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) <   T (y) \\} \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/cac7bccb48da9f576b265ef6ad1329992436784eb111c73accb6f6fad111ffa8.jpg"
                }
