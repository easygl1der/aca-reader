        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. 若  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P\\{N(0,1) > T(y)\\} \\approx 0"
                    },
                    {
                        "type": "text",
                        "content": ", 则可知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T(y) > 0"
                    },
                    {
                        "type": "text",
                        "content": ", 因此"
                    }
                ]
            },
            "bbox": [
                66,
                314,
                751,
                387
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 \\approx P \\{N (0, 1) > T (y) \\} = P \\{N (0, 1) > | T (y) | \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/82c094a22c0b5d954c7490eee2814fb5306b11200d2d1dda817b01f73edb0f42.jpg"
