            "bbox": [
                243,
                300,
                452,
                344
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The classical  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-value for the test statistic  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T(y)"
                    },
                    {
                        "type": "text",
                        "content": " is "
                    }
                ]
            },
            "bbox": [
                246,
                407,
                590,
                446
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p _ {C} = \\Pr \\left(T (y ^ {\\text {r e p}}) \\geq T (y) | \\theta\\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4b238159122f58e4387a394db8d8c6b7a16c53323980dcd3704b57df23e0b27a.jpg"
                }
            },
            "bbox": [
                405,
                500,
                605,
                544
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The probability is taken over the distribution of  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " with  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": " fixed. "
                    }
                ]
            },
            "bbox": [
                261,
                638,
                732,
                672
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "NOTE "
                    }
                ],
                "level": 1
            },
            "bbox": [
                247,
                762,
                296,
                792
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The distribution of  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " given  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": " and  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": " is the same as its distribution given  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": " alone. "
                    }
                ]
            },
