            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "经典检验问题的  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值计算公式"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                719,
                244
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "已知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y_{1}, \\ldots, y_{n} \\sim N(\\theta , 1)"
                    },
                    {
                        "type": "text",
                        "content": ", 检验  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm{H}_{0}"
                    },
                    {
                        "type": "text",
                        "content": ":  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta = \\theta_{0}"
                    },
                    {
                        "type": "text",
                        "content": " 。"
                    }
                ]
            },
            "bbox": [
                89,
                320,
                595,
                381
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\triangleright y = \\left(y _ {1}, \\dots , y _ {n}\\right)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/26c2379b68c01a03ccb11d809ebe991065e87b198bf64dda76a51714d27a0699.jpg"
                }
            },
            "bbox": [
                88,
                453,
                297,
                503
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\succ"
                    },
                    {
                        "type": "text",
                        "content": " 统计量为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T(y) = \\frac{\\bar{y} - \\theta_{0}}{1 / \\sqrt{n}}"
                    }
                ]
            },
            "bbox": [
                87,
                601,
                388,
                698
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "经典检验问题的  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值计算公式"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                719,
                244
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值计算公式:"
                    }
                ]
            },
            "bbox": [
                85,
                296,
                262,
                357
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\triangleright H _ {1} \\colon \\theta > \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) > T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta <   \\theta_ {0} \\colon p _ {c} = P \\{N (0, 1) <   T (y) \\} \\\\ \\triangleright H _ {1} \\colon \\theta \\neq \\theta_ {0} \\colon p _ {c} = P \\{| N (0, 1) | > | T (y) | \\} = 2 P \\{N (0, 1) > | T (y) | \\} \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b5e725d64ab6c258ebd91be3fbb9da29e3a6776ca9a4ee0f9cf496a5a76b6373.jpg"
                }
            },
            "bbox": [
                84,
                414,
                902,
                707
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "若  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p_{c}< \\alpha"
                    },
                    {
                        "type": "text",
                        "content": " （接近0），则拒绝  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm{H}_{0}"
                    }
                ]
            },
            "bbox": [
                85,
                829,
                482,
                892
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "从  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " 角度看  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                463,
                244
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "假设  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm{H}_{0}"
                    },
                    {
                        "type": "text",
                        "content": " 成立, 即  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta = \\theta_{0}"
                    },
                    {
                        "type": "text",
                        "content": ", 亦即  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y_{1}, \\ldots, y_{n} \\sim N\\left(\\theta_{0}, 1\\right)"
                    },
                    {
                        "type": "text",
                        "content": " 。"
                    }
                ]
            },
            "bbox": [
                67,
                292,
                689,
                357
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "现从  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N(\\theta_0, 1)"
                    },
                    {
                        "type": "text",
                        "content": " 中生成的重复数据（replicated data），记为  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y^{\\mathrm{rep}} = (y_1^{\\mathrm{rep}}, \\ldots, y_n^{\\mathrm{rep}})"
                    },
                    {
                        "type": "text",
                        "content": "。"
                    }
                ]
            },
            "bbox": [
                67,
                479,
                929,
                646
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "由于  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y ^{\\mathrm {r e p}}"
                    },
                    {
                        "type": "text",
                        "content": " 与  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": " 来自同一分布, 所谓 “同源”, 因此由  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y ^{\\mathrm {r e p}}"
                    },
                    {
                        "type": "text",
                        "content": " 与  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": " 应该 “相差无几”。"
                    }
                ]
            },
            "bbox": [
                71,
                770,
                930,
                918
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "从  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " 角度看  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": " 值"
                    }
                ],
                "level": 1
            },
            "bbox": [
                96,
                144,
                463,
                244
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "考虑  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\bar{y}^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " 与  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\bar{y}"
                    },
                    {
                        "type": "text",
                        "content": " 的大小关系：由于  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\bar{y}^{\\mathrm{rep}}"
                    },
                    {
                        "type": "text",
                        "content": " 是  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta_0"
                    },
                    {
                        "type": "text",
                        "content": " 的“代表值”， "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\bar{y}"
                    },
                    {
                        "type": "text",
                        "content": " 是  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": " 的“代表值”。"
                    }
                ]
            },
            "bbox": [
                79,
                314,
                893,
                500
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "若  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 成立（ "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta = \\theta_{0}"
                            },
                            {
                                "type": "text",
                                "content": "），则可以预计： "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P(\\overline{y}^{\\mathrm{rep}} > \\overline{y})"
                            },
                            {
                                "type": "text",
                                "content": " 应该接近 0.5。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "反之，若  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P(\\bar{y}^{\\mathrm{rep}} > \\bar{y})"
                            },
                            {
                                "type": "text",
                                "content": " 接近 0 或接近 1；则认为  "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm{H}_{0}"
                            },
                            {
                                "type": "text",
                                "content": " 不成立。"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                66,
                585,
                892,
                801
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "统计量的引入"
                    }
                ],
                "level": 1
            },
            "bbox": [
                94,
                142,
                396,
                235
            ]
        },
        {
            "type": "image",
            "content": {
