            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "若  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p_{c}< \\alpha"
                    },
                    {
                        "type": "text",
                        "content": " （接近0），则拒绝  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm{H}_{0}"
                    }
                ]
            },
            "bbox": [
                531,
