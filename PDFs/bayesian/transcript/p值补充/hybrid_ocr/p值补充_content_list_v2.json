                531
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. 若  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P\\{N(0,1) < T(y)\\} \\approx 0"
                    },
                    {
                        "type": "text",
                        "content": " ，则可知  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T(y) < 0"
                    },
                    {
                        "type": "text",
                        "content": " ，因此"
                    }
                ]
            },
            "bbox": [
                63,
                607,
                743,
                677
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 \\approx P \\{N (0, 1) <   T (y) \\} = P \\{N (0, 1) > - T (y) \\} = P \\{N (0, 1) > | T (y) | \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/80faec8d14aa71fd1ae3d023a53c06dea7e2bca474ece1d70ab2876949384532.jpg"
