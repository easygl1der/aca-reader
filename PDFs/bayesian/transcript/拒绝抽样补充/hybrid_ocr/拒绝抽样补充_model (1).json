            "content": "证明：总体思路"
        },
        {
            "type": "text",
            "bbox": [
                0.086,
                0.297,
                0.322,
                0.356
            ],
            "angle": 0,
            "content": "考虑 \\(x\\) 的分布函数:"
        },
        {
            "type": "equation",
            "bbox": [
                0.169,
                0.422,
                0.834,
                0.753
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} F (t) = P (x \\leq t) = P \\left(x ^ {*} \\leq t \\mid \\text {接 收}\\right) = \\frac {P \\left(x ^ {*} \\leq t , \\text {接 收}\\right)}{P (\\text {接 收})} \\\\ = \\frac {P (x ^ {*} \\leq t , u \\leq r)}{P (u \\leq r)} \\\\ \\end{array}\n\\]"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.148,
                0.348,
                0.239
            ],
            "angle": 0,
            "content": "证明: 分子"
        },
        {
            "type": "equation",
            "bbox": [
                0.15,
                0.331,
                0.851,
                0.684
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} P (x ^ {*} \\leq t, u \\leq r) = \\int_ {- \\infty} ^ {t} \\left\\{\\int_ {0} ^ {p (x ^ {*}) / [ M g (x ^ {*}) ]} 1 \\cdot d u \\right\\} g (x ^ {*}) d x ^ {*} \\\\ = \\int_ {- \\infty} ^ {t} \\frac {p (x ^ {*})}{M g (x ^ {*})} \\times g (x ^ {*}) d x ^ {*} = \\frac {1}{M} \\int_ {- \\infty} ^ {t} p (x ^ {*}) d x ^ {*} \\\\ \\end{array}\n\\]"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.148,
                0.348,
                0.239
            ],
            "angle": 0,
            "content": "证明：分母"
        },
        {
            "type": "equation",
            "bbox": [
                0.178,
                0.301,
                0.828,
                0.774
            ],
            "angle": 0,
            "content": "\\[\n\\begin{array}{l} P (u \\leq r) = P (- \\infty <   x ^ {*} <   + \\infty , u \\leq r) \\\\ = \\int_ {- \\infty} ^ {+ \\infty} \\left\\{\\int_ {0} ^ {p (x ^ {*}) / [ M g (x ^ {*}) ]} 1 \\cdot d u \\right\\} g (x ^ {*}) d x ^ {*} \\\\ = \\int_ {- \\infty} ^ {+ \\infty} \\frac {p (x ^ {*})}{M g (x ^ {*})} \\times g (x ^ {*}) d x ^ {*} = \\frac {1}{M} \\int_ {- \\infty} ^ {+ \\infty} p (x ^ {*}) d x ^ {*} = \\frac {1}{M} \\\\ \\end{array}\n\\]"
        }
    ],
    [
        {
            "type": "title",
            "bbox": [
                0.097,
                0.144,
